# ─────────────────────────────────────────
# REQUIRED: JWT secret for local auth
# Generate with: openssl rand -base64 32
# ─────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-secret-before-deploying

# ─────────────────────────────────────────
# OPTIONAL: Supabase (leave blank for local SQLite)
# Set DB_BACKEND=supabase to activate
# ─────────────────────────────────────────
DB_BACKEND=sqlite
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
